# MSIT Website Environment Variables Example
# Duplicate this file to .env and fill in the values

# Base URL for the site (required for SEO component and canonical links)
VITE_SITE_URL=https://msit-website.netlify.app

# API URL (If used for dynamic content in future)
VITE_API_URL=

# Note: All environment variables must be prefixed with VITE_ to be exposed to React
